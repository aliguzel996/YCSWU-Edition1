    "excludedAppIds": ["ycswu-tools-launcher"],
    "manifestVersion": "0.1.0"
  },
  "assetClasses": [
    {
      "kind": "still-image",
      "label": "image",
      "extensions": ["png", "jpg", "jpeg", "webp", "bmp", "avif", "tif", "tiff"]
    },
    {
      "kind": "vector",
      "label": "vector",
      "extensions": ["svg", "ai", "eps", "pdf"]
    },
    {
      "kind": "animation",
      "label": "animation",
      "extensions": ["gif", "apng"]
    },
    {
      "kind": "video",
      "label": "video",
      "extensions": ["mp4", "mov", "webm", "mkv", "avi"]
    },
    {
      "kind": "model3d",
      "label": "3d model",
      "extensions": ["fbx", "glb", "gltf", "obj", "stl", "dae", "usdz"]
    },
    {
      "kind": "scene",
      "label": "scene",
      "extensions": ["blend", "ycswuscene", "json"]
    },
    {
      "kind": "layout",
      "label": "layout",
      "extensions": ["grid", "layout", "json"]
    },
    {
      "kind": "text",
      "label": "text",
      "extensions": ["txt", "md", "json"]
    },
    {
      "kind": "palette",
      "label": "palette",
      "extensions": ["ase", "aco", "css", "json"]
    },
    {
      "kind": "archive",
      "label": "bundle",
      "extensions": ["zip"]
    }
  ],
  "busAdapters": [
    {
      "id": "bus-rasterize",
      "name": "asset bus rasterizer",
      "from": ["vector", "model3d", "scene", "video", "animation"],
      "to": ["still-image"],
      "mode": "bus"
    },
    {
      "id": "bus-vectorize",
      "name": "asset bus vectorizer",
      "from": ["still-image", "layout", "text"],
      "to": ["vector"],
      "mode": "bus"
    },
    {
      "id": "bus-clip-frame",
      "name": "asset bus frame extractor",
      "from": ["video", "animation"],
      "to": ["still-image"],
      "mode": "bus"
    },
    {
      "id": "bus-motion-pack",
      "name": "asset bus motion packer",
      "from": ["still-image", "vector"],
      "to": ["animation", "video"],
      "mode": "bus"
    },
    {
      "id": "bus-extrude",
      "name": "asset bus extruder",
      "from": ["text", "vector", "layout", "still-image"],
      "to": ["model3d"],
      "mode": "bus"
    },
    {
      "id": "bus-scene-pack",
      "name": "asset bus scene packer",
      "from": ["model3d", "scene", "still-image"],
      "to": ["scene", "model3d"],
      "mode": "bus"
    },
    {
      "id": "bus-package",
      "name": "asset bus packager",
      "from": ["still-image", "vector", "animation", "video", "model3d", "scene", "layout", "text", "palette"],
      "to": ["archive"],
      "mode": "bus"
    }
